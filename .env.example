# ───────────────────────────────────────────────────────────────────────
# Zasder Weather backend configuration
#
# Copy this file to .env, fill in real values, and never commit .env.
# All values can also be passed as environment variables (Fly.io secrets,
# docker compose env, etc.) instead of a file.
# ───────────────────────────────────────────────────────────────────────

# AmbientWeather API credentials.
# Get both from https://ambientweather.net/account → API Keys.
# Application Key is created once for the app; API Key is per-account.
AW_APPLICATION_KEY=replace-with-application-key
AW_API_KEY=replace-with-api-key

# Shared secret the iOS app sends as `Authorization: Bearer <token>`.
# Generate one with:    openssl rand -hex 32
# Treat it like a password — anyone with this token can read your data.
API_TOKEN=generate-a-long-random-string

# Optional secondary bearer token, also accepted by the API.
# Useful for App Store reviewer credentials (give the reviewer this one,
# revoke after approval) or for token rotation without downtime.
# Leave unset to require API_TOKEN only.
# REVIEWER_API_TOKEN=

# How often to poll AmbientWeather, in seconds.
# AWN rate-limits at 1 req/sec per Application Key. 60 is comfortable.
POLL_INTERVAL_SECONDS=60

# Where the SQLite database lives.
# Fly.io: /data/weather.db (persistent volume)
# Docker compose: /data/weather.db (named volume)
# Local dev: ./data/weather.db
DATABASE_PATH=./data/weather.db

# Optional: forecast coordinates for the iOS Forecast strip.
# Leave commented to auto-derive from your station's reported lat/lon.
# FORECAST_LAT=33.4484
# FORECAST_LON=-112.0740

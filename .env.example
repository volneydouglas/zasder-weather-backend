# ───────────────────────────────────────────────────────────────────────
# Zasder Weather backend configuration
#
# Copy this file to .env, fill in real values, never commit .env.
# Every value can also be set via environment variable (Fly.io secrets,
# docker compose env, etc.) instead of a file.
# ───────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────

# Shared secret the iOS app sends as `Authorization: Bearer <token>`.
# Generate with:  openssl rand -hex 32
# Treat like a password — anyone with this token can read all your data.
API_TOKEN=generate-a-long-random-string

# Shared secret used by SDR relays (LilyGO) when POSTing observations
# to /ingest/custom. Distinct from API_TOKEN so revoking write doesn't
# lock the iOS app out. Required if you're running any SDR relay.
# Generate with:  openssl rand -hex 32
INGEST_TOKEN=generate-a-long-random-string

# Where SQLite lives. Fly.io: /data/weather.db (persistent volume).
# Local docker: /data/weather.db (named volume). Local dev: ./data/weather.db
DATABASE_PATH=./data/weather.db

# ── Path A: AmbientWeather cloud poller (optional) ───────────────────
# Set both to enable. Get them from https://ambientweather.net/account.
# Leave unset to skip the AWN poller — it stays asleep silently.
# AW_APPLICATION_KEY=replace-with-application-key
# AW_API_KEY=replace-with-api-key
# AWN rate-limits at 1 req/sec per Application Key. 60s is comfortable.
POLL_INTERVAL_SECONDS=60

# ── Path B: Davis WeatherLink cloud poller (optional) ────────────────
# All three required together to enable. Generate the key + secret at
# https://www.weatherlink.com/account (scroll to "API Key v2" at the
# bottom — Davis intentionally tucks it below the fold).
# Then call /v2/stations once with curl to find your station_id.
# Leave any unset to skip the WeatherLink poller.
# WEATHERLINK_API_KEY=
# WEATHERLINK_API_SECRET=
# WEATHERLINK_STATION_ID=
# WEATHERLINK_NAME=Davis Vantage Pro2 (Cloud)
# WEATHERLINK_LOCATION=Your City
# Poll cadence in seconds. Free tier = 5min data so poll every 300s; Pro+
# = 1min data so 30s is plenty. Floor is 15s.
# WEATHERLINK_POLL_INTERVAL_SECONDS=60
# If your Davis ISS was installed mid-year, the cloud reports yearly
# rain only since pairing. Set the actual prior year-to-date here and
# the poller adds it to every reading so the rollup is real.
# WEATHERLINK_YEARLY_RAIN_BASELINE_IN=0

# ── Path E: Davis WeatherLink LIVE (LAN local poller) ────────────────
# Same Davis hardware as Path B, but polled locally over your LAN — no
# API key, no cloud round-trip, ~6× fresher data. Backend needs NO env
# vars for this path; you just POST to /ingest/custom from a Pi-side
# poller. Configure the poller (WLL_HOST, INGEST_TOKEN, etc.) in
# wll-poller/.env on the Pi — see wll-poller/README.md.
#
# Rain calibration: same INGEST_YEARLY_RAIN_OFFSETS mechanism as the
# LilyGO paths. If you previously had WEATHERLINK_YEARLY_RAIN_BASELINE_IN
# set, use offset = -baseline for the Davis MAC (default 5D:5D:05:00:00:01).

# ── Path C/D: LilyGO ESP32 SDR direct ────────────────────────────────
# The boards themselves are provisioned with backend_url + ingest_token
# via the captive portal (see lilygo-relay/README.md). One backend env
# is needed if you want accurate "rain since calibration" numbers:
#
# LilyGO firmware POSTs the sensor's RAW LIFETIME cumulative counter
# (Atlas rain_in, Fineoffset rain_mm) as rain.yearly_in. Without an
# offset, iOS shows the lifetime total (could be tens of inches) as
# "yearly rain". Set the per-MAC offset to subtract the sensor's
# lifetime cumulative at calibration time so stored yearly_in matches
# actual year-to-date inches.
#
# Format: JSON map of {MAC: offset_inches}. Keys are case-insensitive
# and accept either colonized (5D:5D:01:00:02:C7) or compact (5D5D...)
# forms.
#
# To populate: read the board's first post (curl /api/devices/{mac}/current),
# note the yearlyrainin value, subtract your actual YTD rain, and put
# the difference here.
#
# Example for two LilyGOs whose sensors started at 3.58" (Atlas) and
# 16.76" (Fineoffset) cumulative when calibrated against AWN's 0.73"
# actual YTD:
# INGEST_YEARLY_RAIN_OFFSETS={"5D:5D:01:00:02:C7":2.85,"5D:5D:02:00:00:7D":16.03}
#
# Rain-glitch guard. Applies to ALL /ingest/custom posts (SDR/LilyGO and any
# custom relay) — NOT the built-in AWN/WeatherLink cloud pollers, which don't
# go through /ingest. A single reading whose cumulative yearly rain jumps more
# than this rate (in/hr) × elapsed-time (+ a 0.25" floor for tip jitter) is
# dropped — and ALL rain buckets are nulled for that one reading — since real
# rain ramps gradually while a decode glitch spikes once. 2 in/hr is well
# above any real rainfall. Set 0 to disable.
# INGEST_MAX_RAIN_RATE_IN_PER_HR=2.0

# ── Optional: device-down email alerts ──────────────────────────────
# Email you when a device that was reporting goes quiet (an SDR board
# hangs, a sensor battery dies, a cloud API key expires). Disabled unless
# ALERT_EMAIL_TO and SMTP_HOST are both set. The monitor watches ALL
# devices and is transition-based (baselines on first sight, alerts on
# OK→stale, sends a recovery note on stale→OK).
#
# SMTP transport — set these as SECRETS (they hold a password). Easiest:
# a Gmail account with an App Password (Google account → Security →
# 2-Step Verification → App passwords). Any SMTP provider works.
# ALERT_EMAIL_TO=you@example.com           # comma-separated for multiple
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587                            # 587 STARTTLS (default) or 465 SSL
# SMTP_USERNAME=you@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# ALERT_EMAIL_FROM=you@gmail.com           # defaults to SMTP_USERNAME
# SMTP_SSL=false                           # set true (and PORT=465) for implicit TLS
#
# Thresholds (minutes offline before alerting). SDR boards post every
# ~16s so 10 min catches a hang fast; a 5-min-cadence Davis cloud feed
# wants more slack — override per-MAC. Set a MAC to 0 to stop watching it.
# ALERT_STALE_MINUTES=15
# ALERT_STALE_MINUTES_BY_MAC={"5D:5D:02:00:00:7D":10,"5D:5D:05:00:00:01":20}
# ALERT_CHECK_INTERVAL_SECONDS=60
# ALERT_REPEAT_HOURS=0                      # >0 = re-remind every N h while still down

# ── Optional: push notifications ─────────────────────────────────────
# Alerts (device-down + threshold) can also be delivered as iOS push, not
# just email. There are two ways to enable it — pick ONE, or leave both
# unset to use email only (push needs an Apple Developer account; email
# does not).
#
# (1) Your OWN APNs key — if you build & ship your own iOS app under your
#     own Apple Developer account. Create an "Apple Push Notifications
#     service (APNs)" Auth Key in the Developer portal → Keys. Set these as
#     SECRETS (KEY_P8 holds the .p8 file's contents). ENV is "sandbox" for
#     dev/TestFlight builds, "production" for the App Store.
# APNS_KEY_ID=ABCD123456
# APNS_TEAM_ID=YOURTEAMID
# APNS_KEY_P8="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# APNS_TOPIC=com.yourorg.yourapp
# APNS_ENV=production
#
# (2) A hosted relay — if you use the official Zasder Weather app (App
#     Store) with your own backend. You can't hold Apple's key for that
#     app, so this backend forwards alerts to a relay that does. Get a
#     relay token from the app (Settings → Notifications → enable push);
#     it configures these for you. No Apple account needed on your side.
# APNS_RELAY_URL=https://weather.zasder.com/api/relay/push
# APNS_RELAY_TOKEN=

# ── Optional: App Store reviewer / token rotation ────────────────────
# Secondary bearer token also accepted by /api/*. Use for App Store
# reviewer credentials (revoke after approval) or no-downtime rotation.
# REVIEWER_API_TOKEN=

# ── Optional: cross-device pressure sharing ─────────────────────────
# If a barometer-less device (e.g. an outdoor-only Atlas) is co-located
# with a device that has one (Davis cloud, a WH32B-paired Fineoffset),
# fill the missing pressure tile from the named source MAC. Single-
# location only — leave unset if you have multiple distinct sites.
# SHARED_BAROMETER_SOURCE_MAC=

# ── Optional: forecast + timezone ────────────────────────────────────
# Forecast coordinates for the iOS Forecast strip. If unset, auto-
# derived from your station's reported lat/lon.
# FORECAST_LAT=33.3004
# FORECAST_LON=-111.9379

# IANA timezone for local-time bucketing of rain rollups (daily/hourly/
# weekly/monthly). Defaults to UTC. Set to your zone so "today's rain"
# rolls over at your wall-clock midnight.
#   America/Phoenix  America/New_York  America/Los_Angeles  Europe/London
# TIMEZONE=America/Phoenix

# ───────────────────── Required ─────────────────────

# Where the backend lives. davis-relay POSTs observations to
# $BACKEND_URL/ingest/custom.
BACKEND_URL=https://weather.example.com

# Must match the backend's INGEST_TOKEN secret. Sent as Authorization
# Bearer; never in URL paths, never logged.
INGEST_TOKEN=replace-with-the-backend-ingest-token

# ───────────────────── Davis ISS ─────────────────────

# Transmitter ID 1..8 — the channel shown in the WeatherLink Console
# (set via DIP switches under the ISS battery cover). Default 1 is the
# Davis factory setting.
DAVIS_ID=1
DAVIS_NAME=Davis Vantage Pro2 (SDR)
DAVIS_LOCATION=

# Rain bucket size (inches per tip).
#   0.01    — standard US VP2 (0.254 mm)
#   0.00787 — metric VP2 (0.2 mm)
#   0.00394 — older / large-bucket sensors (0.1 mm)
DAVIS_RAIN_BUCKET_IN=0.01

# Yearly rain baseline (inches). Set to your prior data source's
# yearlyrainin AT DEPLOY TIME (e.g. from AWN or another receiver).
# rtldavis reports a 7-bit free-running tip counter that wraps every
# 128 clicks; we baseline once then accumulate deltas. Leave 0 to
# skip yearly rain reporting entirely.
DAVIS_RAIN_YEARLY_BASELINE_IN=0

# Wind direction calibration offset in degrees. Davis broadcasts raw
# 0-255 mapped linearly to 0-360°; small per-sensor offsets are normal.
DAVIS_WIND_DIR_OFFSET=0

# ───────────────────── Misc ─────────────────────
LOG_LEVEL=INFO

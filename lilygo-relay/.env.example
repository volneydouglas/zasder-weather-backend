# lilygo-relay is provisioned at first boot via WiFiManager's web UI,
# not via .env. This file is here for reference: it lists the two
# values you'll be prompted for in the captive portal once you join
# the "ZasderLilyGO" Wi-Fi AP (WPA2 password "zasder-setup") that the
# board exposes on first power-on.

# Base URL of your Zasder Weather backend (no trailing slash).
BACKEND_URL=https://weather.example.com

# Bearer token the backend accepts on /ingest/custom. Must match the
# backend's INGEST_TOKEN secret. Generate with `openssl rand -hex 32`.
INGEST_TOKEN=replace-with-the-backend-ingest-token

# ───────────────────────────────────────────────────────────────────────
# Acurite (and other-source) relay configuration
#
# This file is for the *local relay* that listens for HTTPS POSTs from
# weather stations that can't reach the cloud backend directly (because
# the station speaks TLS 1.1 and Fly's edge requires TLS 1.2+, etc).
#
# Copy to .env, fill in values, and never commit .env.
# ───────────────────────────────────────────────────────────────────────

# Where to forward parsed observations. Either your Fly.io app
# (https://your-app.fly.dev) or a self-hosted backend on your LAN
# (http://10.0.0.6:8080). Leave both BACKEND_URL and INGEST_TOKEN
# unset to capture-only (writes to ./data/observations.jsonl on disk
# but never forwards anywhere).
BACKEND_URL=https://your-app.fly.dev
INGEST_TOKEN=paste-the-INGEST_TOKEN-the-backend-prints

# Optional: also upload to Wunderground using your PWS credentials.
# Independent of BACKEND_URL — both can be on, both can be off.
# Leave commented to skip.
# WU_STATION_ID=YOUR_PWS_ID
# WU_PASSWORD=your-wu-password

# Optional human labels — overwrite the auto-generated device name and
# location in the iOS app. The hub itself only reports a MAC.
# STATION_NAME=My Atlas
# STATION_LOCATION=Chandler

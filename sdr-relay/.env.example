# ───────────────────── Required ─────────────────────

# Where the backend lives. The container POSTs observations to
# $BACKEND_URL/ingest/custom.
BACKEND_URL=https://weather.example.com

# Must match the backend's INGEST_TOKEN secret. Sent as Authorization
# bearer; never in URL paths, never logged.
INGEST_TOKEN=replace-with-the-backend-ingest-token

# ───────────────────── AcuRite Atlas (433 MHz) ─────────────────────
# Find your Atlas sensor's ID by running:
#   rtl_433 -d "serial=acurite433" -R 40 -F json
# Look for the integer "id" field. Set ATLAS_ID=0 to skip.
ATLAS_ID=0
ATLAS_NAME=AcuRite Atlas (SDR)
ATLAS_LOCATION=
# RTL-SDR Blog V4 EEPROM serial — must match the dongle you marked with:
#   sudo rtl_eeprom -d :<old-serial> -s acurite433
ATLAS_SERIAL=acurite433
# Seconds between coalesced Atlas posts. Atlas cycles 8 message types
# so 60s catches most of them at least once; raise if you want lower
# data volume, lower if you want fresher rolling values.
ATLAS_POST_INTERVAL=60
# AcuRite Atlas units commonly develop UV/lux photodiode failures where
# the firmware broadcasts a stuck value forever (e.g. uv=4 lux=79550
# even at midnight). Symptom: uv/solarradiation never change regardless
# of time of day. Set to 1 to mask both fields as None instead of
# posting bogus values to the backend.
ATLAS_UV_LUX_BROKEN=0

# ───────────────────── Optional LaCrosse-TH2 (433 MHz) ─────────────────────
# Old LaCrosse weather sensors (TX29, TX35, TH2) broadcast temp+humidity
# on 433 MHz. Set LACROSSE_ID to the integer "id" you see in rtl_433
# output (e.g. via /api/discoveries). The Atlas dongle picks it up
# automatically once you add it to the decoder list (we do that for you
# when LACROSSE_ID is nonzero).
LACROSSE_ID=0
LACROSSE_NAME=LaCrosse (SDR)
LACROSSE_LOCATION=
# Yearly-rain calibration. rtl_433 emits a lifetime cumulative counter
# that has no relation to "rain this year". Set to whatever value your
# prior data source reports for yearlyrainin right now (e.g., curl your
# AWN yearlyrainin field) — the SDR baselines once on its first packet,
# then tracks deltas from there. Persisted in /data/rain_state.json so
# restarts don't re-baseline. Leave at 0 to skip yearly rain posting.
ATLAS_RAIN_YEARLY_BASELINE_IN=0

# ───────────────────── Fine Offset / WS-2000 (915 MHz) ─────────────────────
# Outdoor 6-in-1 sensor (WH24 / WH65B / WS80 — same packet shape). Find ID:
#   rtl_433 -d "serial=ws2000" -f 915M -F json
# Look for Fineoffset-WH24 (or -WH65B, -WS80) lines. Set WH24_ID=0 to skip.
WH24_ID=0
# Optional indoor sensor (temp/humidity/pressure). If set, its latest
# values are merged into each WH24 post's `indoor` block so the iOS app
# shows them in the Indoor stat tile. Set WH32B_ID=0 to skip indoor merge.
WH32B_ID=0
WS2000_NAME=WS-2000 (SDR)
WS2000_LOCATION=
WS2000_SERIAL=ws2000
# WS-2000 yearly-rain calibration (see ATLAS_RAIN_YEARLY_BASELINE_IN above).
WS2000_RAIN_YEARLY_BASELINE_IN=0

# Sanity ceiling on rain delta between consecutive packets, in inches.
# Decoders occasionally emit garbage values where the cumulative counter
# jumps from e.g. 19" to 1000". Any single-packet increase exceeding this
# value is rejected and the prior counter is kept. Default 5.0 is far
# above any plausible single-interval rainfall (Hurricane Harvey peaked
# at ~12"/hour ≈ 3"/minute). Lower for very calm climates; set to 0 to
# disable the check entirely.
MAX_RAIN_DELTA_IN=5.0


# ───────────────────── Misc ─────────────────────
LOG_LEVEL=INFO

# ───────────────────── Discovery survey (debug / curiosity) ─────────────────────
# The SDR hears way more than just your sensors — TPMS from passing cars,
# neighbors' weather stations, garage remotes, more utility meters, etc.
# When DISCOVERY_ENABLED=1, every decoded packet's (model, id) is recorded
# to /data/discoveries.json with first/last seen + count + a sample
# payload — local-only, never leaves your LAN. View with:
#     docker exec sdr-relay cat /data/discoveries.json | jq .
DISCOVERY_ENABLED=1

# Set DISCOVERY_FORWARD_TO_BACKEND=1 to also POST each new sighting to
# the backend's /ingest/discovery so it's queryable via /api/discoveries.
# Useful for single-tenant personal deployments. Leave at 0 for any
# multi-tenant or shared deployment — neighbors' RF traffic doesn't
# belong in a shared cloud DB.
DISCOVERY_FORWARD_TO_BACKEND=0
# Minimum seconds between cloud-forward POSTs per unique (model, id).
# Backend already dedupes, this just saves pointless HTTP calls when
# the SDR hears the same device every 18 seconds for hours on end.
DISCOVERY_RATE_LIMIT_S=60

# ───────────────────── Atlas-only — rolling-window gust ─────────────────────
# Some AcuRite Atlas firmware revisions never broadcast a wind_max
# field (type-8 packets don't appear). For those, we synthesize a gust
# reading as max(wind_avg) over a rolling window — matches what the
# AcuRite hub used to compute internally. 600s = 10 minutes is the
# NWS gust-reporting convention.
WIND_GUST_WINDOW_S=600

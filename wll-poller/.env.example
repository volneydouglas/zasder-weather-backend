# ── WeatherLink Live (LAN gateway) ─────────────────────────────────
# Find the IP from your router or the WeatherLink app (Account →
# Devices → your WLL → Device Info). Doesn't have to be static, but
# it should be (DHCP reservation, ideally).
WLL_HOST=10.0.1.56

# How often to poll. WLL refreshes every 2.5s via UDP broadcast and on
# every HTTP request; 10s keeps load tiny and is still ~6× fresher
# than the cloud poller. Drop to 3–5s if you want near-realtime wind.
WLL_POLL_SECONDS=10

# ── Zasder Weather backend ────────────────────────────────────────
# Where to POST observations. The INGEST_TOKEN is the same write-only
# token your backend expects on /ingest/custom (set as a Fly secret, or in
# the backend's .env for local Docker).
BACKEND_URL=https://weather.zasder.com
INGEST_TOKEN=replace-with-your-INGEST_TOKEN

# ── Device identity in the backend ────────────────────────────────
# Synthetic MAC the backend stores observations under. If you ALSO run
# the WeatherLink cloud poller for this same physical Davis station,
# reuse its MAC so both feeds land on one device row — then you can
# disable the cloud poller and let WLL be the only source.
WLL_DEVICE_MAC=5D:5D:05:00:00:01

# Friendly name + location for the device row. Leave both empty to
# preserve whatever name is already on the row (e.g. set by the cloud
# poller's first sighting).
WLL_DEVICE_NAME=
WLL_DEVICE_LOCATION=

# LOG_LEVEL=INFO            # DEBUG for every-tick logs, WARNING to quiet
